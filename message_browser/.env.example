APP_HOST=0.0.0.0
APP_PORT=8090
APP_DEBUG=false

DB_ADAPTER=mysql
DB_TABLE_PREFIX=tdl_

MYSQL_HOST=172.25.80.1
MYSQL_PORT=3308
MYSQL_USER=cjf
MYSQL_PASSWORD=123456
MYSQL_DATABASE=telegram_media_downloader
MYSQL_CHARSET=utf8mb4

SQLITE_PATH=./metadata.db

# 可选：限制可预览文件的根目录，多个用英文逗号分隔；为空表示不限制
MEDIA_ROOTS=

# 小红书发布：mock=只落盘，webhook=推送到你的发布服务
XHS_PUBLISH_MODE=playwright
XHS_WEBHOOK_URL=
XHS_WEBHOOK_TOKEN=
XHS_TIMEOUT=20
XHS_OUTPUT_DIR=./output/xhs_publish

# playwright 真实发布模式配置
XHS_CREATOR_URL=https://creator.xiaohongshu.com/publish/publish
XHS_USER_DATA_DIR=./browser_data
XHS_AUTO_CLICK_PUBLISH=true
XHS_PUBLISH_BUTTON_TEXT=发布
XHS_WAIT_TIMEOUT_MS=90000
# 可选代理(示例: http://172.25.80.1:7890 或 socks5://172.25.80.1:7890)
XHS_PROXY_SERVER=
XHS_PROXY_USERNAME=
XHS_PROXY_PASSWORD=

# AI 文案生成（ModelScope OpenAI兼容接口）
AI_ENABLED=true
AI_API_KEY=
AI_BASE_URL=https://api-inference.modelscope.cn/v1
AI_TEXT_MODEL=Qwen/Qwen3-1.7B
AI_VISION_MODEL=moonshotai/Kimi-K2.5
AI_DEFAULT_USE_VISION=true
AI_MAX_IMAGES=4
AI_TEMPERATURE=0.7
AI_TIMEOUT=120
AI_SYSTEM_PROMPT=你是资深小红书电商文案策划，擅长基于商品图文自动完成受众分析、风格决策与高转化文案生成。
AI_DEFAULT_PROMPT=你将收到商品文本与图片信息，请直接生成小红书种草文案包。不要反问用户，不要分步骤等待确认，自动完成决策。自动识别赛道与人群，在幽默/科普/情感共鸣/实用/分享中选择主风格并给出2个备选，在5种框架中选1个最优。生成5个标题（20字以内，带emoji）+1篇约500字主文案+2篇120-180字A/B短文案。若文本出现批价/进价/拿货价/成本价，将其视为进货价。默认按包邮测算：快递约15元，净利润目标仅5-10元，因此包邮建议价=成本+20到+25；若不包邮则建议价=成本+5到+10。若建议价为整百（100/200/300）优先改99/199/299，但需保证净利润>=5，不足则改为109/209等x9价。严禁在最终标题/正文中出现成本价、进货价、批价、利润等内部信息，对外只写包邮卖价/活动价。若标题中出现价格数字，必须使用对外活动价或建议售价，不得出现接近成本价的数字。忠于输入，不编造参数，规避敏感词和绝对化表达。只输出JSON，字段至少包含title, content, highlights, hashtags, strategy, pricing, titles, style_variants。
